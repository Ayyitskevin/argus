# Argus service environment (copy to .env beside this tree on deploy host)
# Default: mock backend — safe for dev and CI.

ARGUS_VISION_BACKEND=mock
# grok | real (alias) = xAI Grok vision; mock = CI/dev default
ARGUS_VISION_MODEL=grok-4-fast

# Vision provider for the real path — reversible cutover selector (see docs/VISION-PROVIDERS.md).
#   grok = xAI cloud (DEFAULT, unchanged, rollback target)   qwen = local Qwen3-VL (Ollama)
# Switching is a single env change; output/schema/callback are identical. cost_usd=0 for qwen.
# ARGUS_VISION_PROVIDER=grok
# ARGUS_QWEN_BASE_URL=http://mickeybot:11434/v1   # OpenAI-compatible /chat/completions (trusted/local)
# ARGUS_QWEN_VISION_MODEL=qwen3-vl:32b
# ARGUS_QWEN_API_KEY=                              # usually unset for local Ollama
# ARGUS_QWEN_TIMEOUT=180
# ARGUS_QWEN_MAX_IMAGE_PX=1024                     # longest edge of the downsized derivative sent

# Structured-output mode for the Mise vision cutover (OFF = live Grok path unchanged).
# When true, completed Mise-gallery runs also emit the shared vision.schema.json shape
# plus cost_usd/latency_ms to Mise's POST /api/argus/callback (see docs/STRUCTURED-OUTPUT.md).
# ARGUS_STRUCTURED_OUTPUT=false
# ARGUS_STRUCTURED_PROVIDER=argus-grok   # provider label Mise pairs shadow rows on
XAI_API_KEY=
# Homelab Grok spend guard (0 = unlimited; SaaS uses tenant caps instead)
# ARGUS_XAI_DAILY_BUDGET_USD=5.00
# ARGUS_XAI_ESTIMATED_COST_PER_IMAGE=0.02
# ARGUS_VISION_CONCURRENCY=2
# ARGUS_VISION_PREFILTER_ENABLED=true
ARGUS_HOST=0.0.0.0
ARGUS_PORT=8010
ARGUS_PUBLIC_URL=http://127.0.0.1:8010
ARGUS_QUEUE_ENABLED=true
ARGUS_DATA_DIR=/home/kevin-lee/ai-workspace/argus/data

# Optional: bearer token for POST + gated GET exports/history (unset = open)
# ARGUS_API_TOKEN=

# Phase 9 ops
# ARGUS_PROMETHEUS_ENABLED=true
# ARGUS_MAX_QUEUE_DEPTH=100
# ARGUS_JOB_MAX_RETRIES=1
# ARGUS_JOB_RETENTION_DAYS=90

# Folder analyze limits: 0 = entire folder (no cap). Omit API/form limit to use these defaults.
# ARGUS_DEFAULT_ANALYZE_LIMIT=20
# MISE_ARGUS_ANALYZE_LIMIT=0

# Mise gallery path resolution (flow production media root)
# ARGUS_MISE_MEDIA_ROOT=/opt/mise/data/media
# Phase 6: read-only Mise gallery index (same bearer as MISE_ARGUS_TOKEN on flow)
# ARGUS_MISE_URL=http://flow:8400
# ARGUS_MISE_API_TOKEN=
# ARGUS_MISE_TIMEOUT=10
# Structured callback reliable delivery (retry -> dead-letter -> re-deliver).
# ARGUS_MISE_CALLBACK_MAX_ATTEMPTS=3
# ARGUS_MISE_CALLBACK_BACKOFF_BASE=0.5

# Homelab Plutus studio hand-off (same token as PLUTUS_API_TOKEN on :8030)
# ARGUS_PLUTUS_URL=http://127.0.0.1:8030
# ARGUS_PLUTUS_PUBLIC_URL=http://strix-halo-a9-mega:8030
# ARGUS_PLUTUS_TOKEN=
# ARGUS_PLUTUS_TIMEOUT=120

# xAI (required when ARGUS_VISION_BACKEND=grok)
# XAI_TIMEOUT=180

# Phase 10 — SaaS / multi-tenant (off on homelab by default)
# ARGUS_SAAS_MODE=false
# ARGUS_CLOUD_BACKEND=disabled   # disabled | stub | simulated | real
# ARGUS_CLOUD_COST_CAP_USD=0
# ARGUS_CLOUD_MONTHLY_IMAGE_CAP=0
# ARGUS_DEFAULT_VISION_PROVIDER=grok
# ARGUS_TENANT_KEY_PEPPER=change-me   # required distinct secret in production SaaS
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Phase 11 — production SaaS
# ARGUS_STORAGE_BACKEND=local          # local | s3
# ARGUS_S3_BUCKET=
# ARGUS_S3_REGION=us-east-1
# ARGUS_S3_ENDPOINT=                   # MinIO / R2
# ARGUS_S3_ACCESS_KEY=
# ARGUS_S3_SECRET_KEY=
# ARGUS_RATE_LIMIT_ENABLED=true
# ARGUS_RATE_LIMIT_PER_MINUTE=60
# ARGUS_RATE_LIMIT_ANALYZE_PER_MINUTE=20
# ARGUS_AUDIT_LOG_ENABLED=true
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# ARGUS_SAAS_PUBLIC_URL=https://argus.example.com