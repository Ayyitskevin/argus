# Argus Cloud — dedicated SaaS deploy (separate from homelab mickey on :8010)
# Copy to .env on the SaaS host:  cp .env.saas.example .env  &&  edit secrets
#
# Bootstrap:  bash scripts/saas-bootstrap.sh

# --- Core ---
ARGUS_SAAS_MODE=true
ARGUS_VISION_BACKEND=grok
ARGUS_VISION_MODEL=grok-4-fast
XAI_API_KEY=

ARGUS_HOST=0.0.0.0
ARGUS_PORT=8020
ARGUS_SAAS_PUBLIC_URL=http://127.0.0.1:8020

ARGUS_DATA_DIR=/var/lib/argus-saas/data
ARGUS_QUEUE_ENABLED=true

# --- Auth (generate unique values — never reuse homelab token) ---
ARGUS_API_TOKEN=CHANGE_ME_ADMIN_TOKEN
ARGUS_TENANT_KEY_PEPPER=CHANGE_ME_DISTINCT_PEPPER

# --- Metering ---
ARGUS_CLOUD_BACKEND=real
ARGUS_CLOUD_COST_PER_IMAGE=0.00123
ARGUS_CLOUD_COST_CAP_USD=500
ARGUS_CLOUD_MONTHLY_IMAGE_CAP=50000
ARGUS_DEFAULT_VISION_PROVIDER=grok

# --- Phase 11 ops ---
ARGUS_STORAGE_BACKEND=local
ARGUS_RATE_LIMIT_ENABLED=true
ARGUS_RATE_LIMIT_PER_MINUTE=120
ARGUS_RATE_LIMIT_ANALYZE_PER_MINUTE=30
ARGUS_AUDIT_LOG_ENABLED=true
ARGUS_PROMETHEUS_ENABLED=true
ARGUS_STRUCTURED_LOGS=true
ARGUS_CAP_WARNING_THRESHOLD=0.8
# ARGUS_CAP_WEBHOOK_URL=https://hooks.example.com/argus-cap-alerts
# ARGUS_CAP_ALERT_EMAIL=ops@example.com
# ARGUS_SMTP_HOST=smtp.example.com
# ARGUS_SMTP_PORT=587
# ARGUS_SMTP_USER=
# ARGUS_SMTP_PASSWORD=
# ARGUS_SMTP_FROM=argus@example.com
# ARGUS_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# ARGUS_REDIS_URL=redis://127.0.0.1:6379/0

# --- Stripe test mode (Dashboard → Developers → API keys) ---
# Use sk_test_... for development. Run:  python scripts/stripe_setup.py
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID=price_CHANGE_ME

# Webhook forward (local dev):
#   stripe listen --forward-to localhost:8020/webhooks/stripe
# Paste the whsec_... signing secret into STRIPE_WEBHOOK_SECRET above.

# Optional S3 tenant uploads
# ARGUS_STORAGE_BACKEND=s3
# ARGUS_S3_BUCKET=argus-tenant-uploads
# ARGUS_S3_REGION=us-east-1
# ARGUS_S3_ACCESS_KEY=
# ARGUS_S3_SECRET_KEY=